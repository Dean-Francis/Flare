{
  "name": "hello extention of the world",
  "description": "Base Level Extension",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "popup.html",
    "default_icon": "hello_extensions.png"
  },
"content_scripts": [{
		"js": ["gmail_content.js"],
		"matches": [
			"https://mail.google.com/*"
		]
	}],
	"background": {
		"service_worker": "background.js"
	},
	"permissions": [
		"storage"
	]

}
